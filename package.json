{
	"name": "@astrojs/md.root",
	"private": true,
	"type": "module",
	"workspaces": [
		"demo",
		"packages/*"
	],
	"scripts": {
		"bump:patch": "pnpm -r --git-tag-version false version patch",
		"bump:minor": "pnpm -r --git-tag-version false version minor",
		"bump:major": "pnpm -r --git-tag-version false version major",
		"start": "pnpm --filter @astrojs/md.demo start",
		"build": "pnpm --filter @astrojs/md.demo build",
		"serve": "pnpm --filter @astrojs/md.demo serve",
		"release": "pnpm -r publish --access public"
	},
	"prettier": {
		"semi": false,
		"singleQuote": true,
		"trailingComma": "es5",
		"useTabs": true
	},
	"stackblitz": {
		"startCommand": "pnpm start"
	},
	"devDependencies": {
		"astro": "6",
		"types-object": "latest"
	},
	"version": "0.0.2"
}
